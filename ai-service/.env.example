# =============================================================================
# AI Assistant service — environment variables
# =============================================================================
# Copy to `.env` and fill in. On Render, set these in the service's Environment
# tab. Most values are REUSED from the existing Express backend's .env so the
# two services share auth, the database, and the Drive service account.

# --- Auth (MUST match the Express backend exactly) --------------------------
# Same secret the backend signs access tokens with. Required so this service
# can verify the JWTs the app already issues. HS256.
ACCESS_TOKEN_SECRET=copy-from-backend-env

# --- Database (same Atlas cluster as the backend) ---------------------------
# Reuse the backend's MONGODB_URI verbatim. We only read existing collections
# (users for auth, tasks for context); we do not create a new database.
MONGODB_URI=copy-from-backend-env

# --- Google Drive (same service account as the backend) ---------------------
# Reuse the backend's GOOGLE_DRIVE_CREDENTIALS_JSON verbatim — the service
# account fileuploader@safecitiespermaculture.iam.gserviceaccount.com already
# owns/has access to the RAG corpus folders (Animals, Composting and Worms,
# Plants, Permaculture Profile2025.docx).
GOOGLE_DRIVE_CREDENTIALS_JSON=copy-from-backend-env

# Name of the write-back subfolder for saved conversations/summaries. Created
# automatically on first save if it doesn't exist.
AI_CONVERSATIONS_FOLDER_NAME=AI Conversations

# --- Azure OpenAI -----------------------------------------------------------
# DeepSeek-V4-Flash for chat, text-embedding-3-small for embeddings. The
# endpoint is the OpenAI-compatible "/openai/v1" surface of the Azure resource.
# The service boots without these, but /chat, /summarize, and /report return
# 503 until they are set. Startup corpus indexing also needs both Azure blocks.
AZURE_OPENAI_ENDPOINT=https://<resource>.services.ai.azure.com/openai/v1
AZURE_OPENAI_KEY=
AZURE_OPENAI_CHAT_DEPLOYMENT=DeepSeek-V4-Flash
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# The embedding model may live on a DIFFERENT Azure resource/project than chat.
# If so, set these to that resource's endpoint + key; embeddings will use them.
# Leave blank to embed against the same endpoint/key as chat above.
AZURE_OPENAI_EMBEDDING_ENDPOINT=
AZURE_OPENAI_EMBEDDING_KEY=

# --- Azure AI Search --------------------------------------------------------
# Vector store for the Drive corpus. The index is created automatically on
# first run if it doesn't exist.
AZURE_SEARCH_ENDPOINT=https://<service>.search.windows.net
AZURE_SEARCH_KEY=
AZURE_SEARCH_INDEX=afc-estate-corpus

# --- CORS / server ----------------------------------------------------------
# Comma-separated list of allowed frontend origins (the RN/Expo app calls this
# service directly). Mirror the backend's allowedOrigins.
ALLOWED_ORIGINS=http://localhost:8081,https://sc-permaculture.vercel.app,https://afc-estate.vercel.app
